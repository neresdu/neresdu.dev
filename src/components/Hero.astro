---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { personal } from '@/data/profile';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'pt' ? '' : '/en';
---

<section class="container-site pt-20 md:pt-28 pb-12">
  <div class="max-w-3xl animate-fade-in">
    <!-- Tagline -->
    <div
      class="font-mono text-xs md:text-sm tracking-wider mb-4"
      style="color: var(--accent-light);"
    >
      {t('hero.tagline')}
    </div>

    <!-- Headline -->
    <h1 class="text-display font-medium mb-5" style="color: var(--text-primary);">
      {t('hero.title')}
    </h1>

    <!-- Description -->
    <p
      class="text-base md:text-lg leading-relaxed mb-8 max-w-2xl"
      style="color: var(--text-secondary);"
    >
      {t('hero.description')}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3">
      <a href={`${basePath}/#experience`} class="btn-primary">
        {lang === 'pt' ? 'Ver trajetória' : 'View journey'}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={personal.github}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        {t('hero.cta_github')}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>

<!-- Status bar -->
<div
  class="py-4"
  style="border-top: 0.5px solid var(--border); border-bottom: 0.5px solid var(--border); background: var(--bg-secondary);"
>
  <div class="container-site">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-xs" style="color: var(--text-secondary);">
      <span class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background: #639922;"></span>
          <span class="relative inline-flex rounded-full h-2 w-2" style="background: #639922;"></span>
        </span>
        {t('hero.status_available')}
      </span>
      <span>{t('hero.location')} · {personal.timezone}</span>
    </div>
  </div>
</div>
