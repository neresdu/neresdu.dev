---
import { getLangFromUrl, useTranslations } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="container-site py-16 md:py-24">
  <div class="section-label mb-2">01 / {t('about.section')}</div>

  <!-- Title + photo inline (variation 2) -->
  <div class="flex items-center gap-4 md:gap-5 mb-8">
    <!-- Photo placeholder: replace /public/avatar.jpg with your real photo -->
    <div
      class="flex-shrink-0 w-14 h-14 md:w-20 md:h-20 rounded-full overflow-hidden"
      style="background: linear-gradient(135deg, #B5D4F4 0%, #378ADD 100%); border: 0.5px solid var(--border-strong);"
      aria-label="Eduardo Neres"
    >
      <!-- When you add a real photo: <img src="/avatar.jpg" alt="Eduardo Neres" class="w-full h-full object-cover" /> -->
      <div class="w-full h-full flex items-center justify-center font-mono text-[10px] md:text-xs" style="color: #042C53;">
        foto
      </div>
    </div>
    <h2 class="text-2xl md:text-3xl font-medium leading-tight">
      {t('about.title')}
    </h2>
  </div>

  <!-- Body text -->
  <div class="max-w-2xl space-y-4">
    <p class="text-base leading-relaxed" style="color: var(--text-primary);">
      {t('about.p1')}
    </p>
    <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
      {t('about.p2')}
    </p>
    <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
      {t('about.p3')}
    </p>
  </div>
</section>
