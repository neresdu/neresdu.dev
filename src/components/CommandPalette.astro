---
/**
 * Command Palette — opens with ⌘K / Ctrl+K (or "/" as secondary).
 *
 * Provides quick navigation between sections, social links, theme toggle,
 * language switch and utility actions like copying the email.
 *
 * Keyboard:
 *   ⌘K / Ctrl+K — open
 *   /           — open (when not typing in an input)
 *   ↑ ↓         — navigate
 *   ↵           — run selected command
 *   esc         — close
 */
import { getLangFromUrl, useTranslations, getAlternateUrl } from '@i18n/utils';
import { personal } from '@/data/profile';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternateLang = lang === 'pt' ? 'en' : 'pt';
const alternateUrl = getAlternateUrl(Astro.url, alternateLang);
const basePath = lang === 'pt' ? '' : '/en';

const labels = lang === 'pt'
  ? {
      placeholder: 'Procurar por seção, ação ou atalho…',
      group_nav: 'NAVEGAÇÃO',
      group_social: 'SOCIAL',
      group_prefs: 'PREFERÊNCIAS',
      empty: 'Nenhum comando encontrado',
      hint_navigate: 'navegar',
      hint_select: 'selecionar',
      hint_close: 'fechar',
      open_github: 'Abrir GitHub',
      open_linkedin: 'Abrir LinkedIn',
      send_email: 'Enviar email',
      copy_email: 'Copiar email',
      copied: 'Copiado!',
      toggle_theme: 'Alternar tema',
      switch_lang: 'Mudar para English',
    }
  : {
      placeholder: 'Search for a section, action or shortcut…',
      group_nav: 'NAVIGATION',
      group_social: 'SOCIAL',
      group_prefs: 'PREFERENCES',
      empty: 'No commands found',
      hint_navigate: 'navigate',
      hint_select: 'select',
      hint_close: 'close',
      open_github: 'Open GitHub',
      open_linkedin: 'Open LinkedIn',
      send_email: 'Send email',
      copy_email: 'Copy email',
      copied: 'Copied!',
      toggle_theme: 'Toggle theme',
      switch_lang: 'Mudar para Português',
    };
---

<!-- Discovery hint: floating chip that invites users to press ⌘K -->
<button
  id="cmdk-trigger"
  type="button"
  class="cmdk-trigger"
  aria-label={lang === 'pt' ? 'Abrir paleta de comandos' : 'Open command palette'}
  aria-haspopup="dialog"
>
  <svg class="cmdk-trigger-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <circle cx="11" cy="11" r="7" />
    <path d="m20 20-3.5-3.5" stroke-linecap="round" />
  </svg>
  <span class="cmdk-trigger-label">
    {lang === 'pt' ? 'Comandos' : 'Commands'}
  </span>
  <kbd class="cmdk-trigger-kbd">
    <span class="cmdk-kbd-mod">⌘</span>K
  </kbd>
</button>

<!-- Overlay + dialog -->
<div
  id="cmdk-overlay"
  class="cmdk-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cmdk-title"
  aria-hidden="true"
>
  <div class="cmdk-backdrop" data-cmdk-close></div>

  <div class="cmdk-panel" role="document">
    <h2 id="cmdk-title" class="sr-only">Command palette</h2>

    <!-- Search input -->
    <div class="cmdk-search">
      <svg class="cmdk-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" stroke-linecap="round" />
      </svg>
      <input
        id="cmdk-input"
        type="text"
        class="cmdk-input"
        placeholder={labels.placeholder}
        aria-label={labels.placeholder}
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="cmdk-esc-chip">esc</kbd>
    </div>

    <!-- Commands list -->
    <div id="cmdk-list" class="cmdk-list" role="listbox" aria-label="Commands">
      <!-- NAVIGATION -->
      <div class="cmdk-group" data-group="nav">
        <div class="cmdk-group-label">{labels.group_nav}</div>

        <button class="cmdk-item" role="option" data-action="navigate" data-target={`${basePath}/#about`} data-keywords={`about sobre ${t('nav.about').toLowerCase()}`}>
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <circle cx="12" cy="8" r="3.5" />
            <path d="M5 20c0-3.87 3.13-7 7-7s7 3.13 7 7" stroke-linecap="round" />
          </svg>
          <span class="cmdk-item-label">{t('nav.about')}</span>
          <span class="cmdk-item-badge">01</span>
        </button>

        <button class="cmdk-item" role="option" data-action="navigate" data-target={`${basePath}/#stack`} data-keywords="stack tech ferramentas tools">
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <path d="m9 6-6 6 6 6M15 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="cmdk-item-label">{t('nav.stack')}</span>
          <span class="cmdk-item-badge">02</span>
        </button>

        <button class="cmdk-item" role="option" data-action="navigate" data-target={`${basePath}/#experience`} data-keywords={`experience experiência trajetória jobs carreira ${t('nav.experience').toLowerCase()}`}>
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="3" y="7" width="18" height="13" rx="2" />
            <path d="M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2" stroke-linecap="round" />
          </svg>
          <span class="cmdk-item-label">{t('nav.experience')}</span>
          <span class="cmdk-item-badge">03</span>
        </button>

        <button class="cmdk-item" role="option" data-action="navigate" data-target={`${basePath}/#projects`} data-keywords={`projects projetos repos github ${t('nav.projects').toLowerCase()}`}>
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z" stroke-linejoin="round" />
          </svg>
          <span class="cmdk-item-label">{t('nav.projects')}</span>
          <span class="cmdk-item-badge">04</span>
        </button>

        <button class="cmdk-item" role="option" data-action="navigate" data-target={`${basePath}/#now`} data-keywords="now atual agora current focus">
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <path d="M12 2v3m6.36 1.64-2.12 2.12M22 12h-3M17.24 17.24l-2.12-2.12M12 22v-3M6.76 17.24l2.12-2.12M2 12h3M6.76 6.76l2.12 2.12" stroke-linecap="round" />
            <circle cx="12" cy="12" r="3.5" />
          </svg>
          <span class="cmdk-item-label">{t('nav.now')}</span>
          <span class="cmdk-item-badge">05</span>
        </button>

        <button class="cmdk-item" role="option" data-action="navigate" data-target={`${basePath}/#contact`} data-keywords={`contact contato email mensagem ${t('nav.contact').toLowerCase()}`}>
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="cmdk-item-label">{t('nav.contact')}</span>
          <span class="cmdk-item-badge">06</span>
        </button>
      </div>

      <!-- SOCIAL -->
      <div class="cmdk-group" data-group="social">
        <div class="cmdk-group-label">{labels.group_social}</div>

        <button class="cmdk-item" role="option" data-action="external" data-target={personal.github} data-keywords="github git repo">
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-1.96c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.77 0c2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.75.12 3.04.74.8 1.18 1.83 1.18 3.09 0 4.42-2.69 5.4-5.25 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/>
          </svg>
          <span class="cmdk-item-label">{labels.open_github}</span>
          <span class="cmdk-item-hint">↗</span>
        </button>

        <button class="cmdk-item" role="option" data-action="external" data-target={personal.linkedin} data-keywords="linkedin linked in profile network">
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13ZM7.12 20.45H3.55V9h3.57v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.46c.98 0 1.77-.78 1.77-1.73V1.73C24 .77 23.21 0 22.23 0Z"/>
          </svg>
          <span class="cmdk-item-label">{labels.open_linkedin}</span>
          <span class="cmdk-item-hint">↗</span>
        </button>

        <button class="cmdk-item" role="option" data-action="email" data-target={`mailto:${personal.email}`} data-keywords={`email mail contato contact ${personal.email}`}>
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <path d="M4 8h16v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" />
            <path d="m4 8 8 6 8-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="cmdk-item-label">{labels.send_email}</span>
          <span class="cmdk-item-hint">{personal.email}</span>
        </button>

        <button class="cmdk-item" role="option" data-action="copy-email" data-target={personal.email} data-keywords={`copy email copiar clipboard ${personal.email}`}>
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="8" y="8" width="12" height="12" rx="2" />
            <path d="M16 8V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h3" stroke-linecap="round" />
          </svg>
          <span class="cmdk-item-label">{labels.copy_email}</span>
          <span class="cmdk-item-hint">{personal.email}</span>
        </button>
      </div>

      <!-- PREFERENCES -->
      <div class="cmdk-group" data-group="prefs">
        <div class="cmdk-group-label">{labels.group_prefs}</div>

        <button class="cmdk-item" role="option" data-action="toggle-theme" data-keywords="theme tema dark light mode escuro claro">
          <svg class="cmdk-item-icon cmdk-theme-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-linecap="round" />
          </svg>
          <svg class="cmdk-item-icon cmdk-theme-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" stroke-linejoin="round" />
          </svg>
          <span class="cmdk-item-label">{labels.toggle_theme}</span>
          <span class="cmdk-item-hint cmdk-theme-label"></span>
        </button>

        <button class="cmdk-item" role="option" data-action="switch-lang" data-target={alternateUrl} data-keywords="language idioma english português translate">
          <svg class="cmdk-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18M12 3a13.5 13.5 0 0 1 0 18M12 3a13.5 13.5 0 0 0 0 18" stroke-linecap="round" />
          </svg>
          <span class="cmdk-item-label">{labels.switch_lang}</span>
          <span class="cmdk-item-hint">{alternateLang.toUpperCase()}</span>
        </button>
      </div>

      <!-- Empty state -->
      <div id="cmdk-empty" class="cmdk-empty" hidden>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" stroke-linecap="round" />
          <path d="m8 11 3 3 5-5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4" />
        </svg>
        <p>{labels.empty}</p>
      </div>
    </div>

    <!-- Footer with keyboard hints -->
    <div class="cmdk-footer">
      <div class="cmdk-hints">
        <span class="cmdk-hint">
          <kbd>↑</kbd><kbd>↓</kbd>
          {labels.hint_navigate}
        </span>
        <span class="cmdk-hint">
          <kbd>↵</kbd>
          {labels.hint_select}
        </span>
        <span class="cmdk-hint">
          <kbd>esc</kbd>
          {labels.hint_close}
        </span>
      </div>
      <div class="cmdk-brand">
        <span class="cmdk-brand-dot"></span>
        neresdu.dev
      </div>
    </div>

    <!-- Toast for copy feedback -->
    <div id="cmdk-toast" class="cmdk-toast" role="status" aria-live="polite"></div>
  </div>
</div>

<style>
  /* ==========================================================================
     DISCOVERY TRIGGER (floating ⌘K chip in bottom-right)
     ========================================================================== */
  .cmdk-trigger {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 40;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem 0.5rem 0.75rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg-primary) 85%, transparent);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border: 0.5px solid var(--border-strong);
    color: var(--text-secondary);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    transition:
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease;
    box-shadow:
      0 4px 12px -4px rgba(0, 0, 0, 0.08),
      0 0 0 0 color-mix(in srgb, var(--accent-light) 0%, transparent);
  }

  :global(html.dark) .cmdk-trigger {
    box-shadow:
      0 8px 24px -8px rgba(0, 0, 0, 0.6),
      0 0 0 0 color-mix(in srgb, var(--accent-light) 0%, transparent);
  }

  .cmdk-trigger:hover {
    transform: translateY(-2px);
    border-color: var(--accent-light);
    color: var(--text-primary);
    box-shadow:
      0 10px 24px -8px rgba(0, 0, 0, 0.15),
      0 0 0 4px color-mix(in srgb, var(--accent-light) 15%, transparent);
  }

  .cmdk-trigger:active {
    transform: translateY(0);
  }

  .cmdk-trigger-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .cmdk-trigger-label {
    font-weight: 500;
  }

  .cmdk-trigger-kbd {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    padding: 3px 6px;
    border-radius: 5px;
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border-strong);
    color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .cmdk-kbd-mod {
    font-size: 11px;
    font-family: -apple-system, system-ui, sans-serif;
  }

  /* Hide label on small screens, show only icon+kbd */
  @media (max-width: 480px) {
    .cmdk-trigger-label { display: none; }
    .cmdk-trigger {
      padding: 0.5rem 0.625rem;
    }
  }

  /* ==========================================================================
     OVERLAY + PANEL
     ========================================================================== */
  .cmdk-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 1rem 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
  }

  .cmdk-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .cmdk-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--bg-primary) 30%, rgba(0, 0, 0, 0.45));
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
  }

  :global(html.dark) .cmdk-backdrop {
    background: color-mix(in srgb, #000 55%, transparent);
  }

  .cmdk-panel {
    position: relative;
    width: 100%;
    max-width: 640px;
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
    border: 0.5px solid var(--border-strong);
    border-radius: 14px;
    overflow: hidden;
    transform: translateY(8px) scale(0.98);
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow:
      0 0 0 0.5px color-mix(in srgb, var(--accent-light) 20%, transparent),
      0 20px 60px -20px rgba(0, 0, 0, 0.25),
      0 40px 120px -40px rgba(0, 0, 0, 0.3);
  }

  :global(html.dark) .cmdk-panel {
    background: color-mix(in srgb, var(--bg-secondary) 95%, transparent);
    box-shadow:
      0 0 0 0.5px color-mix(in srgb, var(--accent-light) 25%, transparent),
      0 20px 60px -10px rgba(0, 0, 0, 0.6),
      0 40px 120px -20px rgba(0, 0, 0, 0.8);
  }

  .cmdk-overlay.is-open .cmdk-panel {
    transform: translateY(0) scale(1);
  }

  /* Subtle gradient border glow on the top edge */
  .cmdk-panel::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--accent-light) 40%, transparent),
      transparent
    );
    pointer-events: none;
  }

  /* ==========================================================================
     SEARCH INPUT
     ========================================================================== */
  .cmdk-search {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1rem 1rem 1.125rem;
    border-bottom: 0.5px solid var(--border);
  }

  .cmdk-search-icon {
    width: 18px;
    height: 18px;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .cmdk-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 15px;
    padding: 0;
  }

  .cmdk-input::placeholder {
    color: var(--text-tertiary);
  }

  .cmdk-esc-chip {
    padding: 3px 7px;
    border-radius: 5px;
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border);
    color: var(--text-tertiary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.04em;
  }

  /* ==========================================================================
     LIST + GROUPS
     ========================================================================== */
  .cmdk-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
    scroll-behavior: smooth;

    /* Custom scrollbar */
    scrollbar-width: thin;
    scrollbar-color: var(--border-strong) transparent;
  }

  .cmdk-list::-webkit-scrollbar {
    width: 6px;
  }
  .cmdk-list::-webkit-scrollbar-track {
    background: transparent;
  }
  .cmdk-list::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 3px;
  }

  .cmdk-group {
    padding: 0.25rem 0 0.5rem;
  }

  .cmdk-group[hidden] {
    display: none;
  }

  .cmdk-group-label {
    padding: 0.5rem 0.75rem 0.375rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  /* ==========================================================================
     COMMAND ITEM
     ========================================================================== */
  .cmdk-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.625rem 0.75rem;
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: var(--text-secondary);
    transition:
      background-color 0.12s ease,
      color 0.12s ease,
      transform 0.08s ease;
    position: relative;
  }

  .cmdk-item[hidden] {
    display: none;
  }

  .cmdk-item:hover,
  .cmdk-item.is-selected {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  :global(html.dark) .cmdk-item:hover,
  :global(html.dark) .cmdk-item.is-selected {
    background: color-mix(in srgb, var(--bg-tertiary) 60%, transparent);
  }

  /* Accent indicator on the left of selected item */
  .cmdk-item.is-selected::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    background: var(--accent-light);
    border-radius: 0 3px 3px 0;
    box-shadow: 0 0 12px color-mix(in srgb, var(--accent-light) 60%, transparent);
  }

  .cmdk-item:active {
    transform: scale(0.985);
  }

  .cmdk-item-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--text-tertiary);
    transition: color 0.12s ease, transform 0.12s ease;
  }

  .cmdk-item.is-selected .cmdk-item-icon,
  .cmdk-item:hover .cmdk-item-icon {
    color: var(--accent-light);
  }

  .cmdk-item-label {
    flex: 1;
    font-size: 14px;
    font-weight: 400;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cmdk-item-badge {
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-tertiary);
  }

  .cmdk-item-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--text-tertiary);
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Theme icon toggle — show sun in light mode, moon in dark mode */
  :global(html:not(.dark)) .cmdk-theme-moon { display: none; }
  :global(html.dark) .cmdk-theme-sun { display: none; }

  /* ==========================================================================
     EMPTY STATE
     ========================================================================== */
  .cmdk-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2.5rem 1rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  .cmdk-empty svg {
    width: 32px;
    height: 32px;
    opacity: 0.5;
  }

  .cmdk-empty p {
    font-size: 13px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ==========================================================================
     FOOTER
     ========================================================================== */
  .cmdk-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.625rem 1rem;
    border-top: 0.5px solid var(--border);
    background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
    flex-shrink: 0;
  }

  .cmdk-hints {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cmdk-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-tertiary);
  }

  .cmdk-hint kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 4px;
    background: var(--bg-primary);
    border: 0.5px solid var(--border-strong);
    color: var(--text-secondary);
    font-family: inherit;
    font-size: 10px;
  }

  .cmdk-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-tertiary);
  }

  .cmdk-brand-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-light);
    box-shadow: 0 0 6px color-mix(in srgb, var(--accent-light) 60%, transparent);
    animation: cmdk-pulse 2s ease-in-out infinite;
  }

  @keyframes cmdk-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  /* Hide hints on very small screens (keep brand) */
  @media (max-width: 480px) {
    .cmdk-hints { display: none; }
  }

  /* ==========================================================================
     TOAST (copy feedback)
     ========================================================================== */
  .cmdk-toast {
    position: absolute;
    bottom: 3.75rem;
    left: 50%;
    transform: translate(-50%, 8px);
    padding: 0.5rem 0.875rem;
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 12px;
    font-weight: 500;
    border-radius: 8px;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.18s ease,
      transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 8px 24px -6px rgba(0, 0, 0, 0.25);
  }

  .cmdk-toast.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  /* ==========================================================================
     A11Y — screen reader only
     ========================================================================== */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cmdk-overlay,
    .cmdk-panel,
    .cmdk-item,
    .cmdk-trigger,
    .cmdk-toast,
    .cmdk-brand-dot {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<script is:inline define:vars={{ labels }}>
  (function () {
    const overlay = document.getElementById('cmdk-overlay');
    const panel = overlay?.querySelector('.cmdk-panel');
    const input = document.getElementById('cmdk-input');
    const list = document.getElementById('cmdk-list');
    const empty = document.getElementById('cmdk-empty');
    const toast = document.getElementById('cmdk-toast');
    const trigger = document.getElementById('cmdk-trigger');

    if (!overlay || !input || !list) return;

    const items = Array.from(list.querySelectorAll('.cmdk-item'));
    const groups = Array.from(list.querySelectorAll('.cmdk-group'));
    const themeLabelEl = list.querySelector('.cmdk-theme-label');
    let selectedIdx = 0;
    let lastFocus = null;

    // -------- Open / close ------------------------------------------------
    const open = () => {
      lastFocus = document.activeElement;
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      updateThemeLabel();
      input.value = '';
      filter('');
      selectedIdx = 0;
      updateSelection();
      // Focus after the transition so scrolling doesn't jump
      requestAnimationFrame(() => input.focus());
    };

    const close = () => {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastFocus && typeof lastFocus.focus === 'function') {
        lastFocus.focus();
      }
    };

    const toggle = () => {
      overlay.classList.contains('is-open') ? close() : open();
    };

    // -------- Filter ------------------------------------------------------
    const filter = (raw) => {
      const query = raw.trim().toLowerCase();
      let visibleCount = 0;

      items.forEach((el) => {
        const label = (el.querySelector('.cmdk-item-label')?.textContent || '').toLowerCase();
        const keywords = (el.dataset.keywords || '').toLowerCase();
        const match = !query || label.includes(query) || keywords.includes(query);
        el.hidden = !match;
        if (match) visibleCount++;
      });

      // Hide groups with no visible items
      groups.forEach((group) => {
        const hasVisible = Array.from(group.querySelectorAll('.cmdk-item'))
          .some((el) => !el.hidden);
        group.hidden = !hasVisible;
      });

      empty.hidden = visibleCount > 0;
      selectedIdx = 0;
      updateSelection();
    };

    // -------- Keyboard navigation ----------------------------------------
    const visibleItems = () => items.filter((el) => !el.hidden);

    const updateSelection = () => {
      const visible = visibleItems();
      items.forEach((el) => el.classList.remove('is-selected'));
      if (visible.length === 0) return;
      selectedIdx = Math.max(0, Math.min(selectedIdx, visible.length - 1));
      const current = visible[selectedIdx];
      current.classList.add('is-selected');
      current.scrollIntoView({ block: 'nearest' });
    };

    const move = (delta) => {
      const visible = visibleItems();
      if (visible.length === 0) return;
      selectedIdx = (selectedIdx + delta + visible.length) % visible.length;
      updateSelection();
    };

    // -------- Actions -----------------------------------------------------
    const showToast = (text) => {
      toast.textContent = text;
      toast.classList.add('is-visible');
      clearTimeout(showToast._t);
      showToast._t = setTimeout(() => toast.classList.remove('is-visible'), 1400);
    };

    const runAction = (item) => {
      if (!item) return;
      const { action, target } = item.dataset;

      switch (action) {
        case 'navigate': {
          close();
          // Let the overlay start closing before scrolling
          setTimeout(() => {
            if (target && target.startsWith('#')) {
              document.querySelector(target)?.scrollIntoView({ behavior: 'smooth' });
            } else if (target) {
              window.location.href = target;
            }
          }, 60);
          break;
        }
        case 'external': {
          window.open(target, '_blank', 'noopener,noreferrer');
          close();
          break;
        }
        case 'email': {
          window.location.href = target;
          close();
          break;
        }
        case 'copy-email': {
          if (navigator.clipboard && target) {
            navigator.clipboard.writeText(target).then(() => {
              showToast(labels.copied);
              setTimeout(close, 700);
            });
          }
          break;
        }
        case 'toggle-theme': {
          const isDark = document.documentElement.classList.contains('dark');
          const next = isDark ? 'light' : 'dark';
          document.documentElement.classList.toggle('dark', next === 'dark');
          localStorage.setItem('theme', next);
          // Sync existing icons in Header that watch the class
          document.querySelectorAll('.sun-icon').forEach((el) => el.classList.toggle('hidden', next === 'dark'));
          document.querySelectorAll('.moon-icon').forEach((el) => el.classList.toggle('hidden', next === 'light'));
          updateThemeLabel();
          break;
        }
        case 'switch-lang': {
          if (target) window.location.href = target;
          break;
        }
      }
    };

    const updateThemeLabel = () => {
      if (!themeLabelEl) return;
      themeLabelEl.textContent = document.documentElement.classList.contains('dark')
        ? 'light'
        : 'dark';
    };

    // -------- Event wiring -----------------------------------------------

    // Global shortcut: ⌘K / Ctrl+K (or "/" when not typing)
    document.addEventListener('keydown', (e) => {
      const mod = e.metaKey || e.ctrlKey;
      if (mod && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        toggle();
        return;
      }

      const isOpen = overlay.classList.contains('is-open');

      if (!isOpen && e.key === '/' && !isTypingTarget(e.target)) {
        e.preventDefault();
        open();
        return;
      }

      if (!isOpen) return;

      switch (e.key) {
        case 'Escape':
          e.preventDefault();
          close();
          break;
        case 'ArrowDown':
          e.preventDefault();
          move(1);
          break;
        case 'ArrowUp':
          e.preventDefault();
          move(-1);
          break;
        case 'Enter':
          e.preventDefault();
          runAction(visibleItems()[selectedIdx]);
          break;
      }
    });

    const isTypingTarget = (el) => {
      if (!el) return false;
      const tag = el.tagName?.toLowerCase();
      return tag === 'input' || tag === 'textarea' || el.isContentEditable;
    };

    // Trigger button
    trigger?.addEventListener('click', open);

    // Backdrop click to close
    overlay.querySelectorAll('[data-cmdk-close]').forEach((el) => {
      el.addEventListener('click', close);
    });

    // Input filtering
    input.addEventListener('input', (e) => filter(e.target.value));

    // Mouse hover selects the item under cursor
    items.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        const visible = visibleItems();
        const idx = visible.indexOf(item);
        if (idx >= 0) {
          selectedIdx = idx;
          updateSelection();
        }
      });
      item.addEventListener('click', () => runAction(item));
    });

    // Init
    updateThemeLabel();
  })();
</script>
